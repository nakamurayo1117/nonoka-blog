---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SpaceInfo from '../components/SpaceInfo.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, intent } = Astro.props;
const showSpaceInfo = !intent || intent === 'local_booking';

const slotHtml = await Astro.slots.render('default');
const h2Positions = [...slotHtml.matchAll(/<h2[\s>]/g)].map((m) => m.index);
const canSplitAtMidpoint = showSpaceInfo && h2Positions.length >= 2;
const splitIndex = canSplitAtMidpoint ? h2Positions[Math.floor(h2Positions.length / 2)] : slotHtml.length;
const proseFirstHalf = slotHtml.slice(0, splitIndex);
const proseSecondHalf = slotHtml.slice(splitIndex);
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.date-label {
				font-weight: 600;
			}
			.last-updated-on {
				margin-top: 0.25em;
			}
		</style>
		<style is:global>
			.prose h2 {
				position: relative;
				font-size: 1.35rem;
				font-weight: 800;
				margin: 2.5rem 0 1rem;
				padding: 0.65rem 1rem 0.65rem 1.1rem;
				background: linear-gradient(135deg, #F5EEFF, #FFF0F8);
				border-left: 5px solid #9B59B6;
				border-radius: 0 10px 10px 0;
				color: #3D1A6E;
			}
			.prose h3 {
				font-size: 1.1rem;
				font-weight: 700;
				margin: 2rem 0 0.6rem;
				padding: 0 0 0.35rem 0.8rem;
				border-left: 3px solid #FF69B4;
				color: #6B3FA0;
			}
		</style>
		<style is:global>
			.faq-q {
				background: linear-gradient(135deg, #F0E6FF, #FAF0FF);
				border-left: 4px solid #9B59B6;
				border-radius: 10px;
				padding: 0.85rem 1.1rem;
				margin: 1.5rem 0 0.3rem !important;
				font-weight: 700;
				font-size: 1rem;
				color: #6B3FA0;
			}
			.faq-a {
				background: #FFF8FE;
				border: 1px solid #F0C8E0;
				border-left: 4px solid #FF69B4;
				border-radius: 10px;
				padding: 0.85rem 1.1rem;
				margin: 0 0 0.5rem !important;
				font-size: 0.97rem;
				line-height: 1.8;
			}
		</style>
		<style is:global>
			.summary-box {
				background: #F0E6FF;
				border-left: 4px solid #FF69B4;
				border-radius: 8px;
				padding: 1rem 1.5rem;
				margin: 1.5rem 0;
			}
			.summary-box ul {
				padding-left: 1.2rem;
				margin: 0.5rem 0;
			}
			.summary-box li {
				font-size: 0.9rem;
				line-height: 1.6;
				margin-bottom: 0.3rem;
			}
			@media (max-width: 768px) {
				.summary-box {
					padding: 0.75rem 1rem;
				}
				.summary-box li {
					font-size: 0.85rem;
				}
			}
			.toc {
				background: #FAF0FF;
				border: 1px solid #C8A8E9;
				border-radius: 8px;
				padding: 1rem 1.5rem;
				margin: 1.5rem 0;
			}
			.cta-box {
				background: linear-gradient(135deg, #C8A8E9, #FF69B4);
				border-radius: 12px;
				padding: 1.5rem;
				text-align: center;
				margin: 2rem 0;
				color: white;
			}
			.cta-box a {
				background: white;
				color: #9B59B6;
				padding: 12px 32px;
				border-radius: 50px;
				font-weight: bold;
				text-decoration: none;
				display: inline-block;
				margin-top: 0.5rem;
			}
			.nonoka-comment {
				display: flex;
				align-items: flex-start;
				gap: 12px;
				margin: 1.5rem 0;
			}
			.nonoka-comment img {
				width: 60px;
				height: 60px;
				border-radius: 50%;
				object-fit: cover;
			}
			.nonoka-comment .bubble {
				background: #FFF0F8;
				border: 2px solid #FF69B4;
				border-radius: 16px;
				padding: 0.75rem 1rem;
				position: relative;
				font-size: 0.9rem;
			}
			.nonoka-comment .bubble::before {
				content: '';
				position: absolute;
				left: -12px;
				top: 50%;
				transform: translateY(-50%);
				border-width: 8px 12px 8px 0;
				border-style: solid;
				border-color: transparent #FF69B4 transparent transparent;
			}
			.nonoka-comment .bubble::after {
				content: '';
				position: absolute;
				left: -9px;
				top: 50%;
				transform: translateY(-50%);
				border-width: 7px 11px 7px 0;
				border-style: solid;
				border-color: transparent #FFF0F8 transparent transparent;
			}
			.matome-box {
				background: #FFF8E1;
				border-left: 4px solid #FF69B4;
				border-radius: 8px;
				padding: 1rem 1.5rem;
				margin: 1.5rem 0;
			}
			.author-box {
				display: flex;
				align-items: center;
				gap: 14px;
				margin: 0 0 2rem;
				padding: 1rem 1.2rem;
				border: 1.5px solid #E0C8F0;
				border-radius: 12px;
				background: #FAF5FF;
			}
			.author-icon {
				width: 56px;
				height: 56px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.author-name {
				font-weight: bold;
				font-size: 0.95rem;
			}
			.author-desc {
				font-size: 0.8rem;
				color: #888;
			}
			.author-bio {
				font-size: 0.8rem;
				color: #666;
				margin-top: 4px;
				line-height: 1.5;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<span class="date-label">公開日：</span><FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										<span class="date-label">更新日：</span><FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<div class="author-box">
						<img src="/images/nonoka-icon.png" alt="ののか" class="author-icon">
						<div class="author-info">
							<div class="author-name">ののか</div>
							<div class="author-desc">六本木のシネマルームDEARROOM運営者</div>
							<div class="author-bio">アラサー。推し活・カフェ巡り・映画が好きすぎて、六本木にシネマルームを作ってしまいました。</div>
						</div>
					</div>
					<Fragment set:html={proseFirstHalf} />
					{canSplitAtMidpoint && <SpaceInfo />}
					<Fragment set:html={proseSecondHalf} />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// FAQ Q/A styling
			document.querySelectorAll('.prose p').forEach(p => {
				const text = p.textContent.trim();
				if (/^Q[.．]/.test(text)) {
					p.classList.add('faq-q');
				} else if (/^A[.．]/.test(text)) {
					p.classList.add('faq-a');
				}
			});
		</script>
	</body>
</html>
