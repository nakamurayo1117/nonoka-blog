---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const RESERVE_URL = 'https://spacemarket.com/p/AHbhuUbilSKvoqCw'; // TODO: Square予約URLに変更
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title="DEARROOM（ディアルーム）六本木 | シネマルームで推し活"
      description="六本木の完全個室シネマルームDEARROOM。100インチスクリーン×Dolby Atmos×推し色LEDで最高の推し活を。鑑賞会・誕生日会・ひとり推し活に。平日3時間¥3,510〜"
    />
  </head>
  <body class="dr-body">
    <Header />

    <!-- ① HERO -->
    <section class="dr-hero">
      <div class="dr-hero-bg">
        <img src="/images/dearroom/room-cinema.png" alt="DEARROOM シネマルーム" class="dr-hero-img" />
        <div class="dr-hero-overlay"></div>
      </div>
      <div class="dr-hero-content">
        <p class="dr-hero-eyebrow">六本木 完全個室シネマルーム</p>
        <h1 class="dr-hero-title">推しと過ごす、<br />最高の時間を。</h1>
        <p class="dr-hero-sub">100インチ大画面 × Dolby Atmos × 推し色LED<br />あなただけの特別空間がここにあります</p>
        <div class="dr-hero-ratings">
          <span>⭐ 4.9 インスタベース</span>
          <span>⭐ 4.6 スペースマーケット</span>
        </div>
        <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-hero-btn">今すぐ予約する</a>
      </div>
    </section>

    <!-- ② FEATURES -->
    <section class="dr-section dr-features">
      <div class="dr-container">
        <h2 class="dr-section-title">DEARROOMの<span class="dr-accent">4つの特徴</span></h2>
        <div class="dr-features-grid">
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🎬</div>
            <h3>100インチ × Dolby Atmos</h3>
            <p>4Kプロジェクター × JBL BAR 800搭載。映画館を超える没入感で推しのライブ映像・アニメ・映画を。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">💡</div>
            <h3>推し色LEDライティング</h3>
            <p>空間全体のLEDを推しのイメージカラーに変更可能。写真映えする唯一無二の推し活空間に。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🎁</div>
            <h3>持ち込み完全自由</h3>
            <p>食べ物・飲み物・デコレーション用品・推しグッズ、すべて持ち込みOK。ゴミ処理も無料。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🔒</div>
            <h3>完全個室・最大10名</h3>
            <p>他のお客様と顔を合わせないプライベート空間。ひとりから最大10名まで対応。24時間利用可。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ LED GALLERY -->
    <section class="dr-section dr-gallery">
      <div class="dr-container">
        <h2 class="dr-section-title">推し色に染まる<span class="dr-accent">空間</span></h2>
        <p class="dr-section-sub">LEDカラーは自由に変更できます</p>
        <div class="dr-gallery-grid">
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-blue.png" alt="ブルーLED" />
            <span class="dr-gallery-label">ブルー</span>
          </div>
          <div class="dr-gallery-item dr-gallery-main">
            <img src="/images/dearroom/room-party.png" alt="グループ利用" />
            <span class="dr-gallery-label">みんなで推し活</span>
          </div>
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-red.png" alt="レッドLED" />
            <span class="dr-gallery-label">レッド</span>
          </div>
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-green.png" alt="グリーンLED" />
            <span class="dr-gallery-label">グリーン</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ USE CASES -->
    <section class="dr-section dr-usecases">
      <div class="dr-container">
        <h2 class="dr-section-title">こんな<span class="dr-accent">推し活</span>に最適</h2>
        <div class="dr-usecases-grid">
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🎥</span>
            <h3>推し映像鑑賞会</h3>
            <p>ライブBD・映画・アニメ一挙放送を大画面で。仲間と感動を共有できる最高の環境。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🎂</span>
            <h3>推しの誕生日会</h3>
            <p>推し色で空間を演出。祭壇セット・デコレーションも自由に持ち込めます。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">📸</span>
            <h3>祭壇フォト撮影</h3>
            <p>LEDカラーを合わせて撮影会。インスタ映えする推し活フォトが撮れます。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🌙</span>
            <h3>ひとり推し活</h3>
            <p>完全個室だから気兼ねなし。推しと二人きりの時間をとことん堪能して。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ PRICING -->
    <section class="dr-section dr-pricing">
      <div class="dr-container">
        <h2 class="dr-section-title">料金プラン</h2>
        <p class="dr-section-sub">すべて最大10名まで同料金</p>
        <div class="dr-pricing-grid">
          <div class="dr-pricing-card">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">平日デイ</span>
              <p class="dr-pricing-note">〜18:00</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥3,510</strong></li>
              <li><span>6時間</span><strong>¥7,020</strong></li>
              <li><span>9時間</span><strong>¥10,530</strong></li>
            </ul>
          </div>
          <div class="dr-pricing-card">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">平日ナイト</span>
              <p class="dr-pricing-note">18:00〜</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥4,050</strong></li>
              <li><span>6時間</span><strong>¥8,100</strong></li>
              <li><span>9時間</span><strong>¥12,150</strong></li>
            </ul>
          </div>
          <div class="dr-pricing-card dr-pricing-featured">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">週末・祝日</span>
              <p class="dr-pricing-note">終日</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥5,130</strong></li>
              <li><span>6時間</span><strong>¥10,260</strong></li>
              <li><span>9時間</span><strong>¥15,390</strong></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑥ REVIEWS -->
    <section class="dr-section dr-reviews">
      <div class="dr-container">
        <h2 class="dr-section-title">お客様からの<span class="dr-accent">評価</span></h2>
        <div class="dr-ratings-row">
          <div class="dr-rating-badge">
            <span class="dr-rating-stars">⭐⭐⭐⭐⭐</span>
            <span class="dr-rating-num">4.9</span>
            <span class="dr-rating-src">インスタベース</span>
          </div>
          <div class="dr-rating-badge">
            <span class="dr-rating-stars">⭐⭐⭐⭐⭐</span>
            <span class="dr-rating-num">4.6</span>
            <span class="dr-rating-src">スペースマーケット</span>
          </div>
        </div>

        <p class="dr-carousel-hint">← スライドして他のレビューを見る →</p>
        <div class="dr-carousel-wrap">
          <button class="dr-carousel-btn dr-carousel-prev" aria-label="前へ">‹</button>
          <div class="dr-carousel" id="reviewCarousel">
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">天井のプロジェクターの迫力があり、画面も音も迫力がありました！ソファーも大きくてゆったりとYouTubeを見ることができました。また機会があれば利用したいと思います！</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">立地がとても良く、このエリアではかなりコスパが高いと感じました。お部屋も思っていたより清潔感があり、快適に過ごすことができました。入室までの案内も丁寧でスムーズだったので、初めての利用でも安心でした。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">電車の遅延でスタジオ利用時間に到着が間に合わなかったところご連絡したら無料で30分延長していただきました。お心遣いとても有難く思いました。スタジオも落ち着いた雰囲気で心地よく過ごすことができました。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">音楽LIVEのライブ配信を友人と観るために使用しました。設備が充実していて、かつ非常に分かりやすく、とても快適に使えました。ビルがちょっと古いところが気になりましたが、こちらの部屋のせいではないので満足です☺️</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">誕生日会で利用しました。いろいろ質問させていただきましたが、返信も早くとても安心でした。工夫されていてとても使いやすいスペースでした。ゴミ引き取りオプションも良心的でとても快適に過ごすことができました。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">eスポーツの試合観戦で利用しました。回線速度も安定しており、プロジェクターの映りもよく、お部屋も綺麗で大変楽しく使わせていただきました！ごみ捨ても無料オプションで付帯できるのも大変助かりました。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">会社のお疲れ様会で利用しました。快適な絨毯とソファー、大きなスクリーンがあり、誰にも邪魔されることなくメンバーと会話をしっかり楽しむことができました。また利用したいと思います。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">清潔な空間で快適に過ごせました。利用時間中に確認事項がありホストの方にメッセージを送りましたが、迅速に返信いただき大変感謝しております。また機会があれば利用させていただきたいと思います♪</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">六本木駅から少し離れた閑静な場所。イメージ通りの部屋で綺麗でいい感じでした。やり取りもスムーズでとても使いやすかったです。値段も安く、また機会があれば利用したいと思います。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">推しのライブビューイングで6人で利用させていただきました。大きなスクリーンで映像もきれいで、すごく楽しめました！！駅からのアクセスもよく、お部屋も落ち着いた雰囲気でリラックスできました。</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">内装がとても良く、プロジェクターも綺麗に写っていて凄く楽しかったです！また機会があれば使いたいなと思う部屋でした！本当にありがとうございました！</p>
            </div>
            <div class="dr-rcard">
              <p class="dr-rcard-stars">⭐⭐⭐⭐⭐</p>
              <p class="dr-rcard-text">撮影で使用させて頂きました！とても素敵なお部屋で気分良く取り組む事が出来ました！また利用させて頂きたいです！</p>
            </div>
          </div>
          <button class="dr-carousel-btn dr-carousel-next" aria-label="次へ">›</button>
        </div>
      </div>
    </section>

    <!-- ⑦ ACCESS -->
    <section class="dr-section dr-access">
      <div class="dr-container">
        <h2 class="dr-section-title">アクセス</h2>
        <div class="dr-access-box">
          <p class="dr-access-name">DEARROOM 六本木</p>
          <p class="dr-access-addr">東京都港区六本木</p>
          <p class="dr-access-station">🚇 東京メトロ日比谷線・都営大江戸線<br />六本木駅 6番出口 徒歩6分</p>
          <p class="dr-access-hours">🕐 24時間営業</p>
        </div>
      </div>
    </section>

    <!-- ⑧ FAQ -->
    <section class="dr-section dr-faq">
      <div class="dr-container">
        <h2 class="dr-section-title">よくある質問</h2>
        <div class="dr-faq-list">
          <div class="dr-faq-item">
            <div class="dr-faq-q">一人で利用できますか？</div>
            <div class="dr-faq-a">もちろんです。完全個室のため一人でも気兼ねなくご利用いただけます。ひとり推し活を思う存分楽しんでください。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">持ち込みは何でもOKですか？</div>
            <div class="dr-faq-a">食べ物・飲み物・デコレーション用品・推しグッズなど、基本的にすべて持ち込み自由です。ゴミ処理も無料です。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">LEDカラーはどうやって変えますか？</div>
            <div class="dr-faq-a">室内のコントローラーで簡単に変更できます。推しのイメージカラーに合わせてご利用ください。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">自分のデバイスを接続できますか？</div>
            <div class="dr-faq-a">はい、HDMIやミラーリングで接続可能です。スマホ・PC・タブレットからお好きなコンテンツを大画面で楽しめます。</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑨ FINAL CTA -->
    <section class="dr-section dr-cta-section">
      <div class="dr-container dr-cta-inner">
        <h2>推し活、もっと特別に。</h2>
        <p>六本木のシネマルームで、忘れられない時間を。</p>
        <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-cta-btn">予約ページへ進む</a>
      </div>
    </section>

    <Footer />

    <script>
      const carousel = document.getElementById('reviewCarousel');
      document.querySelector('.dr-carousel-prev')?.addEventListener('click', () => {
        carousel?.scrollBy({ left: -300, behavior: 'smooth' });
      });
      document.querySelector('.dr-carousel-next')?.addEventListener('click', () => {
        carousel?.scrollBy({ left: 300, behavior: 'smooth' });
      });
    </script>

    <!-- 固定予約バー -->
    <div class="dr-sticky-bar">
      <span class="dr-sticky-text">平日3時間 ¥3,510〜</span>
      <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-sticky-btn">今すぐ予約</a>
    </div>
  </body>
</html>

<style>
  /* ===== BASE ===== */
  .dr-body {
    background: #FFF8FD;
    color: #2D1A3E;
    font-family: var(--font-noto-sans-jp, sans-serif);
    padding-bottom: 80px;
  }
  .dr-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .dr-accent { color: #FF69B4; }
  .dr-section { padding: 5rem 0; }
  .dr-section-title {
    font-size: 1.7rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 0.5rem;
    color: #2D1A3E;
  }
  .dr-section-sub {
    text-align: center;
    color: #9B7DB8;
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
  }
  .dr-btn-primary {
    display: inline-block;
    background: linear-gradient(90deg, #FF69B4, #9B59B6);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 36px;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(255,105,180,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }
  .dr-btn-primary:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 28px rgba(255,105,180,0.5);
  }

  /* ===== HERO ===== */
  .dr-hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .dr-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .dr-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .dr-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,10,35,0.45) 0%, rgba(20,10,35,0.65) 100%);
  }
  .dr-hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding: 2rem 1.5rem;
  }
  .dr-hero-eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: #FFB3D9;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .dr-hero-title {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 900;
    line-height: 1.25;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }
  .dr-hero-sub {
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(255,255,255,0.9);
    margin-bottom: 1.5rem;
  }
  .dr-hero-ratings {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: #FFD700;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .dr-hero-btn { font-size: 1.1rem; padding: 16px 44px; }

  /* ===== FEATURES ===== */
  .dr-features { background: #fff; }
  .dr-features .dr-section-title { margin-bottom: 2.5rem; }
  .dr-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }
  .dr-feature-card {
    background: #FFF0F8;
    border: 1.5px solid #F5D0E8;
    border-radius: 16px;
    padding: 1.75rem 1.25rem;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .dr-feature-card:hover {
    border-color: #FF69B4;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(255,105,180,0.15);
  }
  .dr-feature-icon { font-size: 2.2rem; margin-bottom: 0.75rem; }
  .dr-feature-card h3 {
    font-size: 0.95rem;
    font-weight: 800;
    color: #2D1A3E;
    margin: 0 0 0.6rem;
  }
  .dr-feature-card p { font-size: 0.82rem; color: #7A5C96; line-height: 1.7; margin: 0; }

  /* ===== GALLERY ===== */
  .dr-gallery { background: #FFF8FD; }
  .dr-gallery .dr-section-title { margin-bottom: 0.3rem; }
  .dr-gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr 1fr;
    grid-template-rows: auto auto;
    gap: 0.75rem;
    margin-top: 2rem;
    border-radius: 16px;
    overflow: hidden;
  }
  .dr-gallery-item {
    position: relative;
    overflow: hidden;
  }
  .dr-gallery-main {
    grid-column: 2;
    grid-row: 1 / 3;
  }
  .dr-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
