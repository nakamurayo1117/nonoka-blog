---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const RESERVE_URL = 'https://spacemarket.com/p/AHbhuUbilSKvoqCw'; // TODO: Square予約URLに変更
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title="DEARROOM（ディアルーム）六本木 | シネマルームで推し活"
      description="六本木の完全個室シネマルームDEARROOM。100インチスクリーン×Dolby Atmos×推し色LEDで最高の推し活を。鑑賞会・誕生日会・ひとり推し活に。平日3時間¥3,510〜"
    />
  </head>
  <body class="dr-body">
    <Header />

    <!-- ① HERO -->
    <section class="dr-hero">
      <div class="dr-hero-bg">
        <img src="/images/dearroom/room-cinema.png" alt="DEARROOM シネマルーム" class="dr-hero-img" />
        <div class="dr-hero-overlay"></div>
      </div>
      <div class="dr-hero-content">
        <p class="dr-hero-eyebrow">六本木 完全個室シネマルーム</p>
        <h1 class="dr-hero-title">推しと過ごす、<br />最高の時間を。</h1>
        <p class="dr-hero-sub">100インチ大画面 × Dolby Atmos × 推し色LED<br />あなただけの特別空間がここにあります</p>
        <div class="dr-hero-ratings">
          <span>⭐ 4.9 インスタベース</span>
          <span>⭐ 4.6 スペースマーケット</span>
        </div>
        <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-hero-btn">今すぐ予約する</a>
      </div>
      <div class="dr-scroll-hint" aria-hidden="true">↓</div>
    </section>

    <!-- ② FEATURES -->
    <section class="dr-section dr-features">
      <div class="dr-container">
        <h2 class="dr-section-title">DEARROOMの<span class="dr-accent">4つの特徴</span></h2>
        <div class="dr-features-grid">
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🎬</div>
            <h3>100インチ × Dolby Atmos</h3>
            <p>4Kプロジェクター × JBL BAR 800搭載。映画館を超える没入感で推しのライブ映像・アニメ・映画を。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">💡</div>
            <h3>推し色LEDライティング</h3>
            <p>空間全体のLEDを推しのイメージカラーに変更可能。写真映えする唯一無二の推し活空間に。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🎁</div>
            <h3>持ち込み完全自由</h3>
            <p>食べ物・飲み物・デコレーション用品・推しグッズ、すべて持ち込みOK。ゴミ処理も無料。</p>
          </div>
          <div class="dr-feature-card">
            <div class="dr-feature-icon">🔒</div>
            <h3>完全個室・最大10名</h3>
            <p>他のお客様と顔を合わせないプライベート空間。ひとりから最大10名まで対応。24時間利用可。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ LED GALLERY -->
    <section class="dr-section dr-gallery">
      <div class="dr-container">
        <h2 class="dr-section-title">推し色に染まる<span class="dr-accent">空間</span></h2>
        <p class="dr-section-sub">LEDカラーは自由に変更できます</p>
        <div class="dr-gallery-grid">
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-blue.png" alt="ブルーLED" />
            <span class="dr-gallery-label">ブルー</span>
          </div>
          <div class="dr-gallery-item dr-gallery-main">
            <img src="/images/dearroom/room-party.png" alt="グループ利用" />
            <span class="dr-gallery-label">みんなで推し活</span>
          </div>
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-red.png" alt="レッドLED" />
            <span class="dr-gallery-label">レッド</span>
          </div>
          <div class="dr-gallery-item">
            <img src="/images/dearroom/room-green.png" alt="グリーンLED" />
            <span class="dr-gallery-label">グリーン</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ USE CASES -->
    <section class="dr-section dr-usecases">
      <div class="dr-container">
        <h2 class="dr-section-title">こんな<span class="dr-accent">推し活</span>に最適</h2>
        <div class="dr-usecases-grid">
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🎥</span>
            <h3>推し映像鑑賞会</h3>
            <p>ライブBD・映画・アニメ一挙放送を大画面で。仲間と感動を共有できる最高の環境。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🎂</span>
            <h3>推しの誕生日会</h3>
            <p>推し色で空間を演出。祭壇セット・デコレーションも自由に持ち込めます。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">📸</span>
            <h3>祭壇フォト撮影</h3>
            <p>LEDカラーを合わせて撮影会。インスタ映えする推し活フォトが撮れます。</p>
          </div>
          <div class="dr-usecase">
            <span class="dr-usecase-emoji">🌙</span>
            <h3>ひとり推し活</h3>
            <p>完全個室だから気兼ねなし。推しと二人きりの時間をとことん堪能して。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ PRICING -->
    <section class="dr-section dr-pricing">
      <div class="dr-container">
        <h2 class="dr-section-title">料金プラン</h2>
        <p class="dr-section-sub">すべて最大10名まで同料金</p>
        <div class="dr-pricing-grid">
          <div class="dr-pricing-card">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">平日デイ</span>
              <p class="dr-pricing-note">〜18:00</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥3,510</strong></li>
              <li><span>6時間</span><strong>¥7,020</strong></li>
              <li><span>9時間</span><strong>¥10,530</strong></li>
            </ul>
          </div>
          <div class="dr-pricing-card">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">平日ナイト</span>
              <p class="dr-pricing-note">18:00〜</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥4,050</strong></li>
              <li><span>6時間</span><strong>¥8,100</strong></li>
              <li><span>9時間</span><strong>¥12,150</strong></li>
            </ul>
          </div>
          <div class="dr-pricing-card dr-pricing-featured">
            <div class="dr-pricing-head">
              <span class="dr-pricing-badge">週末・祝日</span>
              <p class="dr-pricing-note">終日</p>
            </div>
            <ul class="dr-pricing-list">
              <li><span>3時間</span><strong>¥5,130</strong></li>
              <li><span>6時間</span><strong>¥10,260</strong></li>
              <li><span>9時間</span><strong>¥15,390</strong></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑥ REVIEWS -->
    <section class="dr-section dr-reviews">
      <div class="dr-container">
        <h2 class="dr-section-title">お客様からの<span class="dr-accent">評価</span></h2>
        <div class="dr-reviews-grid">
          <div class="dr-review-card">
            <div class="dr-review-stars">⭐⭐⭐⭐⭐</div>
            <p class="dr-review-score">4.9 <span>/ 5.0</span></p>
            <p class="dr-review-source">インスタベース</p>
          </div>
          <div class="dr-review-card">
            <div class="dr-review-stars">⭐⭐⭐⭐⭐</div>
            <p class="dr-review-score">4.6 <span>/ 5.0</span></p>
            <p class="dr-review-source">スペースマーケット</p>
          </div>
        </div>
        <p class="dr-reviews-note">多くの推し活女子にご利用いただいています</p>
      </div>
    </section>

    <!-- ⑦ ACCESS -->
    <section class="dr-section dr-access">
      <div class="dr-container">
        <h2 class="dr-section-title">アクセス</h2>
        <div class="dr-access-box">
          <p class="dr-access-name">DEARROOM 六本木</p>
          <p class="dr-access-addr">東京都港区六本木</p>
          <p class="dr-access-station">🚇 東京メトロ日比谷線・都営大江戸線<br />六本木駅 6番出口 徒歩6分</p>
          <p class="dr-access-hours">🕐 24時間営業</p>
        </div>
      </div>
    </section>

    <!-- ⑧ FAQ -->
    <section class="dr-section dr-faq">
      <div class="dr-container">
        <h2 class="dr-section-title">よくある質問</h2>
        <div class="dr-faq-list">
          <div class="dr-faq-item">
            <div class="dr-faq-q">一人で利用できますか？</div>
            <div class="dr-faq-a">もちろんです。完全個室のため一人でも気兼ねなくご利用いただけます。ひとり推し活を思う存分楽しんでください。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">持ち込みは何でもOKですか？</div>
            <div class="dr-faq-a">食べ物・飲み物・デコレーション用品・推しグッズなど、基本的にすべて持ち込み自由です。ゴミ処理も無料です。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">LEDカラーはどうやって変えますか？</div>
            <div class="dr-faq-a">室内のコントローラーで簡単に変更できます。推しのイメージカラーに合わせてご利用ください。</div>
          </div>
          <div class="dr-faq-item">
            <div class="dr-faq-q">自分のデバイスを接続できますか？</div>
            <div class="dr-faq-a">はい、HDMIやミラーリングで接続可能です。スマホ・PC・タブレットからお好きなコンテンツを大画面で楽しめます。</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑨ FINAL CTA -->
    <section class="dr-section dr-cta-section">
      <div class="dr-container dr-cta-inner">
        <h2>推し活、もっと特別に。</h2>
        <p>六本木のシネマルームで、忘れられない時間を。</p>
        <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-cta-btn">予約ページへ進む</a>
      </div>
    </section>

    <Footer />

    <!-- 固定予約バー -->
    <div class="dr-sticky-bar">
      <span class="dr-sticky-text">平日3時間 ¥3,510〜</span>
      <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="dr-btn-primary dr-sticky-btn">今すぐ予約</a>
    </div>
  </body>
</html>

<style>
  /* ===== BASE ===== */
  .dr-body {
    background: #0A0A12;
    color: #F0EAF8;
    font-family: var(--font-noto-sans-jp, sans-serif);
    padding-bottom: 80px;
  }
  .dr-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .dr-accent { color: #FF69B4; }
  .dr-section {
    padding: 5rem 0;
  }
  .dr-section-title {
    font-size: 1.7rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 0.5rem;
    color: #fff;
  }
  .dr-section-sub {
    text-align: center;
    color: #C0A8D8;
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
  }
  .dr-btn-primary {
    display: inline-block;
    background: linear-gradient(90deg, #FF69B4, #9B59B6);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 36px;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 4px 24px rgba(255,105,180,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }
  .dr-btn-primary:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 32px rgba(255,105,180,0.6);
  }

  /* ===== HERO ===== */
  .dr-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .dr-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .dr-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .dr-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,18,0.55) 0%, rgba(10,10,18,0.75) 100%);
  }
  .dr-hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding: 2rem 1.5rem;
  }
  .dr-hero-eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: #FF69B4;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  .dr-hero-title {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 900;
    line-height: 1.25;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .dr-hero-sub {
    font-size: 1rem;
    line-height: 1.8;
    color: #E8D8F5;
    margin-bottom: 1.5rem;
  }
  .dr-hero-ratings {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: #FFD700;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .dr-hero-btn { font-size: 1.1rem; padding: 16px 44px; }
  .dr-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255,255,255,0.4);
    font-size: 1.5rem;
    animation: drBounce 2s ease-in-out infinite;
  }
  @keyframes drBounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== FEATURES ===== */
  .dr-features { background: #100D1A; }
  .dr-features .dr-section-title { margin-bottom: 2.5rem; }
  .dr-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .dr-feature-card {
    background: #1A1428;
    border: 1px solid #2D2040;
    border-radius: 16px;
    padding: 1.75rem 1.25rem;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
  }
  .dr-feature-card:hover {
    border-color: #FF69B4;
    transform: translateY(-3px);
  }
  .dr-feature-icon { font-size: 2.2rem; margin-bottom: 0.75rem; }
  .dr-feature-card h3 {
    font-size: 0.95rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.6rem;
  }
  .dr-feature-card p { font-size: 0.82rem; color: #B098C8; line-height: 1.7; margin: 0; }

  /* ===== GALLERY ===== */
  .dr-gallery { background: #0A0A12; }
  .dr-gallery .dr-section-title { margin-bottom: 0.3rem; }
  .dr-gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr 1fr;
    grid-template-rows: auto auto;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .dr-gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }
  .dr-gallery-main {
    grid-column: 2;
    grid-row: 1 / 3;
  }
  .dr-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }
  .dr-gallery-item:hover img { transform: scale(1.04); }
  .dr-gallery-label {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    background: rgba(0,0,0,0.6);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  /* ===== USE CASES ===== */
  .dr-usecases { background: #100D1A; }
  .dr-usecases .dr-section-title { margin-bottom: 2.5rem; }
  .dr-usecases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 1.5rem;
  }
  .dr-usecase {
    background: linear-gradient(135deg, #1A1428, #160F24);
    border: 1px solid #2D2040;
    border-radius: 16px;
    padding: 1.75rem 1.25rem;
    text-align: center;
  }
  .dr-usecase-emoji { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
  .dr-usecase h3 { font-size: 0.95rem; font-weight: 800; color: #fff; margin: 0 0 0.5rem; }
  .dr-usecase p { font-size: 0.82rem; color: #B098C8; line-height: 1.7; margin: 0; }

  /* ===== PRICING ===== */
  .dr-pricing { background: #0A0A12; }
  .dr-pricing .dr-section-title { margin-bottom: 0.3rem; }
  .dr-pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .dr-pricing-card {
    background: #1A1428;
    border: 1px solid #2D2040;
    border-radius: 16px;
    overflow: hidden;
  }
  .dr-pricing-featured {
    border-color: #FF69B4;
    box-shadow: 0 0 0 1px #FF69B4, 0 8px 30px rgba(255,105,180,0.2);
  }
  .dr-pricing-head {
    padding: 1.2rem 1.5rem 0.8rem;
    border-bottom: 1px solid #2D2040;
    text-align: center;
  }
  .dr-pricing-badge {
    display: inline-block;
    background: linear-gradient(90deg, #FF69B4, #9B59B6);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 4px 16px;
    border-radius: 20px;
    margin-bottom: 0.3rem;
  }
  .dr-pricing-note { font-size: 0.78rem; color: #B098C8; margin: 0.3rem 0 0; }
  .dr-pricing-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.5rem 1.25rem;
  }
  .dr-pricing-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #1E1730;
    font-size: 0.9rem;
  }
  .dr-pricing-list li:last-child { border-bottom: none; }
  .dr-pricing-list span { color: #C0A8D8; }
  .dr-pricing-list strong { color: #fff; font-size: 1rem; }

  /* ===== REVIEWS ===== */
  .dr-reviews { background: #100D1A; }
  .dr-reviews .dr-section-title { margin-bottom: 2rem; }
  .dr-reviews-grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .dr-review-card {
    background: #1A1428;
    border: 1px solid #2D2040;
    border-radius: 16px;
    padding: 2rem 3rem;
    text-align: center;
    min-width: 180px;
  }
  .dr-review-stars { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .dr-review-score {
    font-size: 2.2rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
  }
  .dr-review-score span { font-size: 1rem; color: #B098C8; }
  .dr-review-source { font-size: 0.85rem; color: #C0A8D8; margin: 0.25rem 0 0; }
  .dr-reviews-note { text-align: center; color: #B098C8; font-size: 0.85rem; margin-top: 1.5rem; }

  /* ===== ACCESS ===== */
  .dr-access { background: #0A0A12; }
  .dr-access .dr-section-title { margin-bottom: 2rem; }
  .dr-access-box {
    background: #1A1428;
    border: 1px solid #2D2040;
    border-radius: 16px;
    padding: 2rem 2.5rem;
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }
  .dr-access-name { font-size: 1.2rem; font-weight: 800; color: #fff; margin: 0 0 0.5rem; }
  .dr-access-addr { font-size: 0.9rem; color: #C0A8D8; margin: 0 0 1rem; }
  .dr-access-station { font-size: 0.9rem; line-height: 1.8; color: #E8D8F5; margin: 0 0 0.75rem; }
  .dr-access-hours { font-size: 0.9rem; color: #FF69B4; font-weight: 700; margin: 0; }

  /* ===== FAQ ===== */
  .dr-faq { background: #100D1A; }
  .dr-faq .dr-section-title { margin-bottom: 2.5rem; }
  .dr-faq-list { max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; }
  .dr-faq-item { border-radius: 12px; overflow: hidden; }
  .dr-faq-q {
    background: linear-gradient(135deg, #2A1E40, #231830);
    color: #E8C8F5;
